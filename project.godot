; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "HttpRouter",
"class": "HttpFileRouter",
"language": "GDScript",
"path": "res://addons/godottpd/fileroutercustom.gd"
}, {
"base": "Reference",
"class": "HttpRequest",
"language": "GDScript",
"path": "res://addons/godottpd/http_request.gd"
}, {
"base": "Reference",
"class": "HttpResponse",
"language": "GDScript",
"path": "res://addons/godottpd/http_response.gd"
}, {
"base": "Reference",
"class": "HttpRouter",
"language": "GDScript",
"path": "res://addons/godottpd/http_router.gd"
}, {
"base": "Node",
"class": "HttpServer",
"language": "GDScript",
"path": "res://addons/godottpd/http_server.gd"
} ]
_global_script_class_icons={
"HttpFileRouter": "",
"HttpRequest": "",
"HttpResponse": "",
"HttpRouter": "",
"HttpServer": ""
}

[application]

config/name="FMPLite"
run/main_scene="res://Control.tscn"
config/use_hidden_project_data_directory=false
config/use_custom_user_dir=true
config/custom_user_dir_name="FMPLite"
config/icon="res://assets/icons/512x512.png"

[autoload]

Global="*res://Global.gd"
REQ="*res://REQ.tscn"

[display]

window/size/width=1
window/size/height=1
window/size/resizable=false
window/size/borderless=true

[editor_plugins]

enabled=PoolStringArray( "res://addons/godottpd/plugin.cfg" )

[gui]

common/drop_mouse_on_gui_input_disabled=true

[physics]

common/enable_pause_aware_picking=true

[rendering]

quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_environment="res://default_env.tres"
